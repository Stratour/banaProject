msgstr "Period of the subscription"

#: stripe_sub/templates/stripe_sub/subscription.html:107
msgid "Vous n’avez pas encore d’abonnement actif."
msgstr "You do not have an active subscription yet."

#: stripe_sub/templates/stripe_sub/subscription.html:116
msgid "S’abonner pour"
msgstr "Subscribe for"

#: stripe_sub/templates/stripe_sub/subscription.html:116
msgid "ans"
msgstr "years"
